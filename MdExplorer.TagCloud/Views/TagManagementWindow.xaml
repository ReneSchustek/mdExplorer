<Window x:Class="MdExplorer.TagCloud.Views.TagManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MdExplorer.TagCloud.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Tag-Verwaltung"
        Width="720"
        Height="520"
        MinWidth="520"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance Type=vm:TagManagementViewModel}">
    <DockPanel LastChildFill="True" Margin="12">
        <TextBlock DockPanel.Dock="Top"
                   FontWeight="SemiBold"
                   Text="Projektweite Tag-Verwaltung"
                   Margin="0,0,0,8" />

        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Text="{Binding StatusMessage}"
                       Foreground="#FF4F5560" />
            <Button Grid.Column="1"
                    Content="Schliessen"
                    IsCancel="True"
                    Width="100"
                    Padding="6,2" />
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" LastChildFill="True">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Tag-Liste" VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="Neu laden"
                            Command="{Binding RefreshCommand}"
                            Padding="6,2" />
                </Grid>
                <DataGrid ItemsSource="{Binding Items}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          AlternatingRowBackground="#FFF7F8FA"
                          BorderBrush="#FFD0D7DE"
                          BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"
                                            Width="*" />
                        <DataGridTextColumn Header="Slug"
                                            Binding="{Binding Slug}"
                                            Width="*" />
                        <DataGridTextColumn Header="Dateien"
                                            Binding="{Binding Count}"
                                            Width="Auto" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>

            <Border Grid.Column="1" Width="1" Margin="12,0" Background="#FFD0D7DE" />

            <StackPanel Grid.Column="2">
                <TextBlock Text="Aktion" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock TextWrapping="Wrap"
                           Text="Waehlen Sie einen Tag aus, tragen Sie den Ziel-Namen ein (ohne fuehrendes '#') und waehlen Sie 'Umbenennen' oder 'Zusammenfuehren'. 'Loeschen' arbeitet ohne Ziel-Namen." />

                <TextBlock Margin="0,12,0,4" Text="Ausgewaehlter Tag" />
                <TextBox IsReadOnly="True"
                         Text="{Binding SelectedItem.Name, Mode=OneWay, FallbackValue=''}" />

                <TextBlock Margin="0,8,0,4" Text="Neuer Name (Ziel)" />
                <TextBox Text="{Binding NewTagName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Umbenennen"
                            Command="{Binding RenameCommand}"
                            Margin="0,0,8,0"
                            Padding="10,4" />
                    <Button Content="Zusammenfuehren"
                            Command="{Binding MergeCommand}"
                            Margin="0,0,8,0"
                            Padding="10,4" />
                    <Button Content="Loeschen"
                            Command="{Binding DeleteCommand}"
                            Padding="10,4" />
                </StackPanel>

                <ProgressBar Height="6"
                             Margin="0,12,0,0"
                             IsIndeterminate="{Binding IsBusy}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
            </StackPanel>
        </Grid>
    </DockPanel>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
</Window>
