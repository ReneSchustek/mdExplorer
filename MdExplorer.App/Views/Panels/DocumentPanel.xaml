<UserControl x:Class="MdExplorer.App.Views.Panels.DocumentPanel"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MdExplorer.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:DocumentPanelViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                BorderBrush="#FFD0D7DE"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ToggleButton Grid.Column="0"
                              x:Name="ModeToggle"
                              Content="Bearbeiten"
                              Padding="8,2"
                              IsChecked="{Binding IsEditMode, Mode=OneWay}"
                              Command="{Binding ToggleModeCommand}"
                              ToolTip="Lese-/Bearbeiten-Modus umschalten (Strg+E)" />
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                    <Button Margin="6,0,0,0"
                            Padding="8,2"
                            Content="✏️ Bearbeiten"
                            Command="{Binding Editor.EnterEditModeCommand}"
                            Visibility="{Binding Editor.IsLocked, Converter={StaticResource BoolToVis}}"
                            ToolTip="Bearbeiten-Modus aktivieren — danach koennen Aenderungen gespeichert werden" />
                    <Button Margin="6,0,0,0"
                            Padding="8,2"
                            Content="👁 Anzeigen"
                            Command="{Binding Editor.ExitEditModeCommand}"
                            ToolTip="Zurueck in den Anzeigen-Modus">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Editor.IsLocked}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Margin="6,0,0,0"
                            Padding="8,2"
                            Content="Speichern"
                            Command="{Binding SaveCommand}"
                            ToolTip="Aenderungen speichern (Strg+S)" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#FF6C7086"
                           Text="{Binding Editor.StatusMessage, Mode=OneWay, FallbackValue=''}"
                           TextTrimming="CharacterEllipsis" />
            </Grid>
        </Border>
        <Border DockPanel.Dock="Top"
                Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                BorderBrush="#FFE5E7EB"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Text="Tags:" Margin="0,0,6,0" FontWeight="SemiBold" />
                <TextBox DockPanel.Dock="Left"
                         Width="120"
                         VerticalAlignment="Center"
                         Margin="0,0,4,0"
                         Text="{Binding Editor.TagInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Neuen Tag eingeben und 'Hinzufuegen' druecken">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding Editor.AddTagCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Button DockPanel.Dock="Left"
                        Content="+"
                        Padding="6,2"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Command="{Binding Editor.AddTagCommand}"
                        ToolTip="Tag hinzufuegen" />
                <ItemsControl ItemsSource="{Binding Editor.Tags}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="2"
                                    Padding="6,1"
                                    Background="#FFEDF1F7"
                                    BorderBrush="#FFB8C2D9"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                    <Button Margin="6,0,0,0"
                                            Padding="4,0"
                                            Content="x"
                                            FontSize="10"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.Editor.RemoveTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Tag entfernen" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border x:Name="FindBar"
                    Grid.Row="0"
                    Visibility="Collapsed"
                    Background="#FFF6F8FA"
                    BorderBrush="#FFD0D7DE"
                    BorderThickness="0,0,0,1"
                    Padding="6,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,6,0" Text="Suchen:" />
                    <TextBox x:Name="FindInput"
                             Width="220"
                             VerticalAlignment="Center"
                             KeyDown="OnFindInputKeyDown"
                             TextChanged="OnFindTextChanged" />
                    <Button Margin="6,0,0,0"
                            Padding="6,2"
                            Content="▼"
                            Click="OnFindNextClick"
                            ToolTip="Naechster Treffer (Enter / F3)" />
                    <Button Margin="2,0,0,0"
                            Padding="6,2"
                            Content="▲"
                            Click="OnFindPreviousClick"
                            ToolTip="Vorheriger Treffer (Shift+Enter / Shift+F3)" />
                    <TextBlock x:Name="FindStatus"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Foreground="#FF6C7086" />
                    <Button Margin="12,0,0,0"
                            Padding="6,2"
                            Content="x"
                            Click="OnFindCloseClick"
                            ToolTip="Suche schliessen (Esc)" />
                </StackPanel>
            </Border>
            <Grid Grid.Row="1">
                <ContentControl x:Name="PreviewHost"
                                Visibility="{Binding IsReadMode, Converter={StaticResource BoolToVis}}" />
                <TextBox x:Name="EditorTextBox"
                         Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                         FontFamily="Consolas, Courier New, monospace"
                         FontSize="13"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         IsReadOnly="{Binding Editor.IsLocked}"
                         Text="{Binding Editor.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
