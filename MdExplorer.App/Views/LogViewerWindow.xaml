<Window x:Class="MdExplorer.App.Views.LogViewerWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MdExplorer.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Live-Log"
        Width="960"
        Height="520"
        MinWidth="640"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance Type=vm:LogViewerViewModel}">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" BorderBrush="#FFD0D7DE" BorderThickness="0,0,0,1" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Level:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox x:Name="LevelComboBox"
                              ItemsSource="{Binding LevelFilters}"
                              SelectedItem="{Binding SelectedLevelFilter, Mode=TwoWay}"
                              DisplayMemberPath="Display"
                              MinWidth="140" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Suche:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox x:Name="SearchTextBox"
                             Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             MinWidth="240" />
                </StackPanel>
                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Exportieren…"
                            Command="{Binding ExportCommand}"
                            Padding="12,4"
                            Margin="0,0,8,0" />
                    <Button Content="Schließen"
                            Width="100"
                            IsCancel="True"
                            Click="OnCloseClick" />
                </StackPanel>
            </Grid>
        </Border>
        <Border DockPanel.Dock="Bottom" BorderBrush="#FFD0D7DE" BorderThickness="0,1,0,0" Padding="8,4">
            <TextBlock>
                <Run Text="Sichtbare Einträge: " />
                <Run Text="{Binding VisibleCount, Mode=OneWay}" FontWeight="SemiBold" />
                <Run Text=" / Puffer: " />
                <Run Text="{Binding Entries.Count, Mode=OneWay}" />
            </TextBlock>
        </Border>
        <ListView ItemsSource="{Binding FilteredView}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  GridViewColumnHeader.Click="OnHeaderClick">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Zeit" Width="180">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss.fff'}" FontFamily="Consolas" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Level" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Level}" FontFamily="Consolas" FontWeight="SemiBold" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Quelle" Width="220">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SourceContext}" FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Nachricht" Width="420">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
