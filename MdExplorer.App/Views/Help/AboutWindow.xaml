<Window x:Class="MdExplorer.App.Views.Help.AboutWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MdExplorer.App.ViewModels.Help"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Über MdExplorer"
        Width="520"
        Height="500"
        MinWidth="420"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        d:DataContext="{d:DesignInstance Type=vm:AboutViewModel}">
    <DockPanel LastChildFill="True" Margin="16">
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="MdExplorer" FontSize="22" FontWeight="SemiBold" />
            <TextBlock Margin="0,2,0,0" Foreground="#FF57606A">
                <Run Text="Version " />
                <Run Text="{Binding Version, Mode=OneWay}" FontWeight="SemiBold" />
            </TextBlock>
            <TextBlock Margin="0,2,0,12" Foreground="#FF57606A">
                <Run Text="Build " />
                <Run Text="{Binding BuildDateDisplay, Mode=OneWay}" />
            </TextBlock>
            <TextBlock Text="Eingesetzte Open-Source-Bibliotheken" FontWeight="SemiBold" Margin="0,8,0,4" />
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Schließen" Width="100" IsDefault="True" IsCancel="True" Click="OnCloseClick" />
        </StackPanel>
        <DataGrid ItemsSource="{Binding Libraries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Paket" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Lizenz" Binding="{Binding License}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
