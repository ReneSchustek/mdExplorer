<Window x:Class="MdExplorer.App.Views.MainWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MdExplorer.App.ViewModels"
        xmlns:panels="clr-namespace:MdExplorer.App.Views.Panels"
        Title="{Binding Title}"
        Width="1280"
        Height="800"
        MinWidth="800"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Closed="OnClosed"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Datei">
                <MenuItem x:Name="SettingsMenuItem"
                          Header="Einstellungen…"
                          InputGestureText="Strg+,"
                          Click="OnSettingsMenuItemClick" />
            </MenuItem>
            <MenuItem Header="Ansicht">
                <MenuItem Header="Tag-Cloud"
                          IsCheckable="True"
                          InputGestureText="Strg+T"
                          IsChecked="{Binding IsTagCloudVisible, Mode=TwoWay}" />
                <MenuItem Header="Tag-Verwaltung…" Click="OnTagManagementMenuItemClick" />
                <MenuItem Header="Graph…" Click="OnGraphMenuItemClick" />
                <Separator />
                <MenuItem Header="Logs…" Click="OnLogViewerMenuItemClick" />
            </MenuItem>
            <MenuItem Header="Hilfe">
                <MenuItem Header="Handbuch…"
                          InputGestureText="F1"
                          Click="OnHelpMenuItemClick" />
                <MenuItem Header="Über MdExplorer…"
                          Click="OnAboutMenuItemClick" />
            </MenuItem>
        </Menu>
        <Border DockPanel.Dock="Top"
                Background="#FFFFF8E1"
                BorderBrush="#FFFFE082"
                BorderThickness="0,0,0,1"
                Padding="12,6"
                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap">
                    <Run Text="Neue Version" />
                    <Run Text="{Binding UpdateVersion, Mode=OneWay}" FontWeight="SemiBold" />
                    <Run Text="verfügbar." />
                    <Hyperlink NavigateUri="{Binding UpdateReleaseUrl, Mode=OneWay}"
                               RequestNavigate="OnUpdateLinkRequestNavigate">Release öffnen</Hyperlink>
                </TextBlock>
                <Button Grid.Column="1"
                        Content="✕"
                        Width="24"
                        Height="24"
                        Margin="8,0,0,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Hinweis schließen"
                        Command="{Binding DismissUpdateCommand}" />
            </Grid>
        </Border>
        <Border DockPanel.Dock="Bottom" BorderBrush="#FFD0D7DE" BorderThickness="0,1,0,0" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0"
                         Width="12"
                         Height="12"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"
                         Cursor="Hand"
                         MouseLeftButtonUp="OnHealthIndicatorClick"
                         ToolTip="{Binding HealthDetail, Mode=OneWay}">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#FF22C55E" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Health}" Value="Warning">
                                    <Setter Property="Fill" Value="#FFFACC15" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Health}" Value="Error">
                                    <Setter Property="Fill" Value="#FFEF4444" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Grid.Column="1">
                    <Run Text="Indizierte Dateien: " />
                    <Run Text="{Binding IndexedFileCount, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
                <TextBlock Grid.Column="2"
                           HorizontalAlignment="Center"
                           Text="{Binding LastIndexerRunUtc, Mode=OneWay, StringFormat='Letzter Indexer-Lauf: {0:yyyy-MM-dd HH:mm} UTC', TargetNullValue='Letzter Indexer-Lauf: —'}" />
                <TextBlock Grid.Column="3"
                           Text="{Binding StorageLocation, Mode=OneWay}"
                           Foreground="#FF6C7086" />
            </Grid>
        </Border>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="FolderColumn" MinWidth="200" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition x:Name="PreviewColumn" MinWidth="320" />
                <ColumnDefinition x:Name="TagCloudSplitterColumn" Width="6" />
                <ColumnDefinition x:Name="TagCloudColumn" Width="260" MinWidth="180" />
            </Grid.ColumnDefinitions>

            <TabControl Grid.Column="0"
                        x:Name="LeftTabs"
                        BorderThickness="0"
                        SelectedIndex="{Binding LeftTabIndex, Mode=TwoWay}"
                        SelectionChanged="OnLeftTabsSelectionChanged">
                <TabItem Header="Ordner">
                    <panels:FolderTreePanel DataContext="{Binding FolderTree}" />
                </TabItem>
                <TabItem Header="Alle Dateien" x:Name="AllFilesTabItem">
                    <ContentControl x:Name="AllFilesHost" DataContext="{Binding AllFiles}" />
                </TabItem>
                <TabItem Header="Suche" x:Name="SearchTabItem">
                    <panels:SearchPanel x:Name="SearchPanelControl" DataContext="{Binding Search}" />
                </TabItem>
            </TabControl>
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#FFE5E7EB" />
            <ContentControl x:Name="DocumentHost" Grid.Column="2" DataContext="{Binding DocumentPanel}" />
            <GridSplitter x:Name="TagCloudSplitter" Grid.Column="3" Width="6" HorizontalAlignment="Stretch" Background="#FFE5E7EB" />
            <ContentControl x:Name="TagCloudHost" Grid.Column="4" DataContext="{Binding TagCloud}" />
        </Grid>
    </DockPanel>
</Window>
