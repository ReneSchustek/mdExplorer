<Window x:Class="MdExplorer.App.Views.Settings.SettingsWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MdExplorer.App.ViewModels.Settings"
        xmlns:views="clr-namespace:MdExplorer.App.Views.Settings"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Einstellungen"
        Width="640"
        Height="520"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance Type=vm:SettingsWindowViewModel}">
    <DockPanel LastChildFill="True" Margin="8">
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0">
            <Button Content="Abbrechen" Command="{Binding CancelCommand}" Width="100" Margin="0,0,8,0" />
            <Button Content="Anwenden" Command="{Binding ApplyAndCloseCommand}" Width="100" IsDefault="True" />
        </StackPanel>
        <TabControl>
            <TabItem Header="Indexierung">
                <views:IndexingTab DataContext="{Binding Indexing}" />
            </TabItem>
            <TabItem Header="Darstellung">
                <views:AppearanceTab DataContext="{Binding Appearance}" />
            </TabItem>
            <TabItem Header="Verhalten">
                <views:BehaviorTab DataContext="{Binding Behavior}" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
