<Window x:Class="MdExplorer.App.Views.Graph.GraphWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:MdExplorer.App.ViewModels.Graph"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WikiLink-Graph"
        Width="1000"
        Height="700"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance Type=vm:GraphViewModel}">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top" BorderBrush="#FFD0D7DE" BorderThickness="0,0,0,1" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Pfad-Prefix:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Grid.Column="1"
                         x:Name="PathPrefixInput"
                         Text="{Binding PathPrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         VerticalAlignment="Center"
                         Padding="4,2"
                         ToolTip="Optionaler Pfad-Filter (relativ zum Root, Trennzeichen / oder \). Leer = alle Pfade." />
            </Grid>
        </Border>
        <Border DockPanel.Dock="Bottom" BorderBrush="#FFD0D7DE" BorderThickness="0,1,0,0" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center">
                    <Run Text="Knoten: " />
                    <Run Text="{Binding NodeCount, Mode=OneWay}" FontWeight="SemiBold" />
                    <Run Text=" von " />
                    <Run Text="{Binding OriginalNodeCount, Mode=OneWay}" FontWeight="SemiBold" />
                    <Run Text="   Kanten: " />
                    <Run Text="{Binding EdgeCount, Mode=OneWay}" FontWeight="SemiBold" />
                    <Run Text=" von " />
                    <Run Text="{Binding OriginalEdgeCount, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
                <Button Grid.Column="1"
                        Content="Neu laden"
                        Command="{Binding RefreshCommand}"
                        Padding="10,2" />
            </Grid>
        </Border>
        <Grid>
            <wv2:WebView2 x:Name="GraphView" />
            <Border Background="#FFFFFFFF"
                    Opacity="0.92"
                    Padding="24"
                    CornerRadius="6"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    BorderBrush="#FFD0D7DE"
                    BorderThickness="1"
                    MaxWidth="520">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding NodeCount}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               FontSize="14"
                               Margin="0,0,0,8"
                               Text="Noch keine Graph-Daten verfügbar" />
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#FF4B5563"
                               Text="Moegliche Ursachen: der Indexer ist gerade noch dabei, deine Workspaces einzulesen, oder die Markdown-Dateien enthalten noch keine [[WikiLinks]]. Schliesse das Fenster nicht — der Klick auf „Neu laden“ aktualisiert die Anzeige." />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
