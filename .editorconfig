# EditorConfig – https://editorconfig.org
root = true

# Alle Dateien
[*]
charset = utf-8
end_of_line = crlf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# C# Quellcode
[*.cs]
indent_size = 4
# Namespace-Deklaration: file-scoped (namespace Foo;)
dotnet_style_namespace_declarations = file_scoped:warning

# ── Vereinfachungen erzwingen ────────────────────────────────────────────────
# using-Anweisungen ohne Block (using var x = ...; statt using (var x = ...) { })
csharp_prefer_simple_using_statement = true:warning
# Sammlungs-Initialisierung: [] statt new List<T>() wo möglich (C# 12+)
dotnet_style_collection_expression = true:warning
# Target-Typed new: new() statt new ClassName() wenn Typ aus Kontext klar
csharp_style_implicit_object_creation_when_type_is_apparent = true:warning
# Vereinfachte default-Ausdrücke: default statt default(T)
csharp_prefer_simple_default_expression = true:warning
# Pattern Matching bevorzugen wo sinnvoll
csharp_style_prefer_pattern_matching = true:suggestion
# Switch-Expressions statt switch-Statements (wenn lesbar)
csharp_style_prefer_switch_expression = true:suggestion
# Unnötige Zuweisungen vermeiden
dotnet_diagnostic.IDE0059.severity = warning

# =========================
# Bug Prevention
# =========================

# Nullability (kritisch)
dotnet_diagnostic.CS8600.severity = error
dotnet_diagnostic.CS8602.severity = error
dotnet_diagnostic.CS8618.severity = error

# Async Fehler verhindern
dotnet_diagnostic.CS4014.severity = error

# Resource / Dispose
dotnet_diagnostic.CA2000.severity = error
dotnet_diagnostic.CA2213.severity = error

# Unused Code
dotnet_diagnostic.CS0168.severity = error
dotnet_diagnostic.CS0219.severity = error
dotnet_diagnostic.IDE0060.severity = error

# ConfigureAwait vergessen vermeiden
dotnet_diagnostic.CA2007.severity = warning

# =========================
# Security (security.md)
# =========================

# SQL-Injection
dotnet_diagnostic.CA2100.severity = error

# Schwacher Zufallsgenerator (System.Random fuer Security)
dotnet_diagnostic.CA5394.severity = error

# Unsichere Deserialisierung
dotnet_diagnostic.CA2300.severity = error
dotnet_diagnostic.CA2301.severity = error
dotnet_diagnostic.CA2302.severity = error

# Hardcodierte Verschluesselung
dotnet_diagnostic.CA5350.severity = error
dotnet_diagnostic.CA5351.severity = error

# Unsichere TLS-Version
dotnet_diagnostic.CA5364.severity = error

# Cookie ohne HttpOnly/Secure
dotnet_diagnostic.CA5382.severity = error
dotnet_diagnostic.CA5383.severity = error

# Unsichere Cipher-Modi (ECB)
dotnet_diagnostic.CA5358.severity = error

# Path-Traversal
dotnet_diagnostic.CA3003.severity = error

# XSS
dotnet_diagnostic.CA3002.severity = error

# =========================
# Resilience (resilience.md)
# =========================

# async void (Prozess-Absturz bei unbehandelter Exception)
dotnet_diagnostic.VSTHRD100.severity = error

# Task.Result / Task.Wait (Deadlock)
dotnet_diagnostic.CA1849.severity = error

# IDisposable korrekt implementieren
dotnet_diagnostic.CA1816.severity = warning

# =========================
# Architecture (architecture.md)
# =========================

# Nicht verwendete private Member entfernen
dotnet_diagnostic.IDE0051.severity = error

# Nicht verwendeter Ausdruck
dotnet_diagnostic.IDE0058.severity = warning

# Kein generischer Exception-Catch
dotnet_diagnostic.CA1031.severity = warning

# Static-faehige Methoden
dotnet_diagnostic.CA1822.severity = suggestion

# Logger-Performance
dotnet_diagnostic.CA1848.severity = suggestion

# =========================
# StyleCop (BRIEF65)
# =========================

# Repo-Konvention: using-Direktiven AUSSERHALB des Namespaces. stylecop.json setzt das,
# trotzdem hier explizit erlaubt, weil viele StyleCop-Default-Regeln das gegenteilig
# konfigurieren wuerden.
dotnet_diagnostic.SA1200.severity = none

# `this.`-Praefix nicht erzwingen (moderner C#-Stil).
dotnet_diagnostic.SA1101.severity = none

# Eingebaute Typen (`int`/`string`/...) statt `Int32`/`String` zulassen.
# Wird bereits ueber `dotnet_style_predefined_type_*` geregelt.
dotnet_diagnostic.SA1121.severity = none

# `_camelCase` fuer private Felder ist Repo-Konvention.
dotnet_diagnostic.SA1309.severity = none

# Trailing-Kommas: erzwingen wir nicht (kein konsistenter Repo-Stil).
dotnet_diagnostic.SA1413.severity = none

# Regions sind erlaubt; sie strukturieren grosse XAML-Code-behinds.
dotnet_diagnostic.SA1124.severity = none

# File-Header: wir haben keinen Copyright-Banner pro Datei.
dotnet_diagnostic.SA1633.severity = none
dotnet_diagnostic.SA1636.severity = none
dotnet_diagnostic.SA1637.severity = none
dotnet_diagnostic.SA1638.severity = none
dotnet_diagnostic.SA1640.severity = none
dotnet_diagnostic.SA1641.severity = none
dotnet_diagnostic.SA1649.severity = none

# Dokumentations-Pflicht nur fuer oeffentliche Elemente (siehe stylecop.json).
# Interne/private Elemente bleiben pragmatisch undokumentiert.
dotnet_diagnostic.SA1600.severity = none
dotnet_diagnostic.SA1601.severity = none
dotnet_diagnostic.SA1602.severity = none
dotnet_diagnostic.SA1623.severity = none
dotnet_diagnostic.SA1629.severity = none
dotnet_diagnostic.SA1642.severity = none
dotnet_diagnostic.SA1643.severity = none

# Layout-Detail-Regeln, die mit `dotnet format` kollidieren oder uebertrieben sind.
dotnet_diagnostic.SA1502.severity = none
dotnet_diagnostic.SA1503.severity = none
dotnet_diagnostic.SA1512.severity = none
dotnet_diagnostic.SA1515.severity = none
dotnet_diagnostic.SA1516.severity = none

# Operatoren auf Zeilenende vs. Zeilenanfang: Repo nimmt beide Stile in Anspruch.
dotnet_diagnostic.SA1107.severity = none

# Konstruktor-Aufruf `: this(...)` Doku-Pflicht.
dotnet_diagnostic.SA1648.severity = none

# Reihenfolge: Static vor Instanz, public vor private, modifier-order. Bleibt auf
# suggestion — fuer Senior-Reviews sichtbar, kein Hard-Fail. SA1201 ist hart deaktiviert,
# weil StyleCop 1.1.118 bei `record`/`record struct`-Deklarationen mit AD0001
# (`KeyNotFoundException`) abstuerzt. Re-enabling erfordert eine neue StyleCop-Version.
dotnet_diagnostic.SA1201.severity = none
dotnet_diagnostic.SA1202.severity = suggestion
dotnet_diagnostic.SA1203.severity = suggestion
dotnet_diagnostic.SA1204.severity = suggestion
dotnet_diagnostic.SA1214.severity = suggestion

# Layout: Closing brace + blank line (sehr noisy, kein Bug-Risiko).
dotnet_diagnostic.SA1513.severity = none

# `new` ohne Trailing-Space: target-typed `new()` ist Standard ab C# 9.
dotnet_diagnostic.SA1000.severity = none

# Parameter-Naming fuer Records (PascalCase ist konventionsgemaess).
dotnet_diagnostic.SA1313.severity = none

# Opening square bracket spacing (`[` als Collection-Expression).
dotnet_diagnostic.SA1010.severity = none

# Closing parenthesis spacing — kollidiert mit Nullable-Annotation `)?`.
dotnet_diagnostic.SA1009.severity = none

# Operator-/Modifier-Reihenfolge mit `required public`: StyleCop kennt den `required`
# Modifier (C# 11) noch nicht korrekt — false positives.
dotnet_diagnostic.SA1206.severity = none

# Using-Reihenfolge: `dotnet format` + editorconfig regeln das bereits.
dotnet_diagnostic.SA1208.severity = none
dotnet_diagnostic.SA1210.severity = none

# Layout-Detailregeln auf none, weil `dotnet format` autoritativ ist.
dotnet_diagnostic.SA1111.severity = none
dotnet_diagnostic.SA1128.severity = none
dotnet_diagnostic.SA1501.severity = none
dotnet_diagnostic.SA1505.severity = none
dotnet_diagnostic.SA1508.severity = none

# Discard-Variable `_` darf gross beginnen.
dotnet_diagnostic.SA1312.severity = none

# XML-Doc-Analyse: in App-Modul deaktiviert (GenerateDocumentationFile=false),
# StyleCop meldet das als SA0001. Kein Bug-Risiko.
dotnet_diagnostic.SA0001.severity = none

# Documentation-Tag-Reihenfolge (param vor returns) sehr pedantisch, deaktivieren.
dotnet_diagnostic.SA1611.severity = suggestion
dotnet_diagnostic.SA1612.severity = suggestion
dotnet_diagnostic.SA1614.severity = suggestion
dotnet_diagnostic.SA1615.severity = suggestion
dotnet_diagnostic.SA1616.severity = suggestion
dotnet_diagnostic.SA1618.severity = suggestion
dotnet_diagnostic.SA1619.severity = suggestion
dotnet_diagnostic.SA1622.severity = suggestion
dotnet_diagnostic.SA1625.severity = suggestion
dotnet_diagnostic.SA1626.severity = suggestion
dotnet_diagnostic.SA1627.severity = suggestion
dotnet_diagnostic.SA1634.severity = suggestion
dotnet_diagnostic.SA1635.severity = suggestion
dotnet_diagnostic.SA1639.severity = suggestion

# =========================
# Sonar (BRIEF65)
# =========================

# TODO-Tracking: hart als Warning, damit jeder neue TODO in BRIEF muendet.
dotnet_diagnostic.S1135.severity = warning

# String-Literal-Duplikate: hart als Warning; Locale-Strings/UI-Texte werden als Konstanten extrahiert.
dotnet_diagnostic.S1192.severity = warning

# Cognitive/Cyclomatic Complexity: Suggestion-Level, damit der Erst-Pass nicht in
# Refactoring-Schleifen reisst. Trotzdem sichtbar fuer kuenftige Senior-Reviews.
dotnet_diagnostic.S3776.severity = suggestion
dotnet_diagnostic.S1541.severity = suggestion

# Parametergleichheit fuer Vergleichsmethoden — hart als Warning.
dotnet_diagnostic.S2342.severity = warning

# Magic-Number-Detection: zu aggressiv (selbst 0/1/2/10/100 schlagen an). Auf Suggestion.
dotnet_diagnostic.S109.severity = suggestion

# Empty-Block-Hinweis: legitime Faelle wie ICommand.CanExecuteChanged Event-Akzessor
# werden lokal per #pragma supprimiert (mit Begruendung).
dotnet_diagnostic.S108.severity = warning

# Make-Static: WPF-ViewModels mit Binding-Setup werden lokal mit #pragma supprimiert.
dotnet_diagnostic.S2325.severity = warning

# LINQ-Replacement-Vorschlag: hart als Warning; Hot-Paths bei Bedarf lokal supprimiert.
dotnet_diagnostic.S3267.severity = warning

# Index-Mutation in for-Schleifen: Skip-Ahead-Faelle lokal mit #pragma + Begruendung.
dotnet_diagnostic.S127.severity = warning

# Projekt- und Config-Dateien
[*.{csproj,props,targets,xml}]
indent_size = 2

# JSON / YAML
[*.{json,yml,yaml}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# XAML
[*.xaml]
indent_size = 4
